# Database
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=kigalipack_db

# Server
PORT=3000
NODE_ENV=development
API_VERSION=v1
API_SUNSET_DATE=2026-12-31

# CORS (comma-separated origins; omit to allow all in development)
# CORS_ORIGIN=https://app.kigali-pack.rw,https://dashboard.kigali-pack.rw

# Redis (rate limiting, caching, queues)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT (organization RBAC)
JWT_SECRET=change-this-in-production

# Admin / internal service authentication
# ADMIN_API_KEY=
# INTERNAL_API_KEY=

# Test API key (plain text — store only the hash in DB)
# Authorization: Bearer kp_test_your_secret_token_here
